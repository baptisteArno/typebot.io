{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "tui": {
    "enabled": false
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript"
    },
    {
      "plugin": "@nx/next/plugin"
    },
    {
      "plugin": "@nx/vite/plugin",
      "exclude": ["apps/landing-page/vite.config.ts"]
    }
  ],
  "targetDefaults": {
    "@nx/esbuild:esbuild": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^default"]
    },
    "@nx/vitest:test": {
      "cache": true,
      "inputs": ["default", "^default"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  },
  "analytics": false
}
