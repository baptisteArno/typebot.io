{
  "name": "workflows",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "nx": {
    "targets": {
      "start": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun src/index.ts"
        }
      },
      "dev": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{workspaceRoot}/apps/workflows",
          "command": "bun --watch --no-clear-screen src/index.ts"
        }
      }
    }
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.30",
    "@effect/sql-pg": "4.0.0-beta.30",
    "@sentry/bun": "^10.43.0",
    "@typebot.io/config": "workspace:*",
    "@typebot.io/lib": "workspace:*",
    "@typebot.io/prisma": "workspace:*",
    "@typebot.io/results": "workspace:*",
    "@typebot.io/telemetry": "workspace:*",
    "@typebot.io/typebot": "workspace:*",
    "@typebot.io/user": "workspace:*",
    "effect": "4.0.0-beta.30"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9"
  }
}
