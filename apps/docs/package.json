{
  "name": "docs",
  "private": true,
  "devDependencies": {
    "mintlify": "4.0.228",
    "tsx": "^4.19.1",
    "dotenv-cli": "^8.0.0"
  },
  "nx": {
    "targets": {
      "mintlify:dev": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "apps/docs",
          "command": "bunx mintlify dev --port 3004"
        }
      },
      "mintlify:check-broken-links": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "apps/docs",
          "command": "bunx mintlify broken-links"
        }
      }
    }
  }
}
