{
  "name": "@typebot.io/source",
  "version": "3.15.2",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/deprecated/*",
    "packages/embeds/*",
    "packages/forge/*",
    "packages/forge/blocks/*",
    "packages/blocks/*",
    "apps/*"
  ],
  "nx": {
    "targets": {
      "format-and-lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bunx biome check ."
        }
      },
      "lint-repo": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bunx sherif -r unordered-dependencies -r packages-without-package-json --ignore-package @typebot.io/legacy --ignore-package bot-engine"
        }
      }
    }
  },
  "scripts": {
    "postinstall": "cd packages/env && bun run compile && nx prisma:generate prisma",
    "prepare": "husky && effect-language-service patch",
    "pre-commit": "nx run-many -t format-and-lint,lint-repo,check-broken-links,test --parallel=4",
    "dev": "nx run-many --configuration=development -t dev,watch-deps -p builder,viewer --parallel=4",
    "format-and-lint:fix": "biome check . --write --unsafe",
    "lint-repo:fix": "bun lint-repo --fix",
    "patch-embed-libs": "bun packages/scripts/src/patchEmbedLibs.ts && bun install",
    "start-docker-compose-dev": "docker compose -f docker-compose.dev.yml up",
    "build-docker-compose-prod": "docker compose -f docker-compose.build.yml build",
    "start-docker-compose-prod": "docker compose -f docker-compose.yml up",
    "sync-locales": "dotenv -e .env -- tolgee sync --continue-on-warning --remove-unused --no-strict-namespace --patterns './apps/builder/src/**/*.ts?(x)' --backup './.tolgee/backup'",
    "pull-locales": "dotenv -e .env -- tolgee pull && bun format-and-lint:fix",
    "push-locales": "dotenv -e .env -- tolgee push",
    "create-new-block": "cd packages/forge/cli && bun start",
    "check-unused-dependencies": "bun packages/scripts/src/checkDependencies.ts",
    "restore": "echo 'Cleaning...' && bunx rimraf --glob '**/{node_modules,dist,.next}'",
    "deploy-workflows": "fly deploy --config apps/workflows/fly.toml"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@effect/language-service": "^0.76.0",
    "@nx/esbuild": "22.5.2",
    "@nx/js": "22.5.2",
    "@nx/next": "22.5.2",
    "@nx/vite": "22.5.2",
    "@nx/web": "22.5.2",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.13",
    "@swc/helpers": "~0.5.19",
    "@tolgee/cli": "^2.16.1",
    "effect-solutions": "^0.4.13",
    "esbuild": "^0.27.3",
    "husky": "^9.1.7",
    "jiti": "2.6.1",
    "nx": "22.5.2",
    "rimraf": "^6.1.3",
    "sherif": "^1.10.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": "24.x"
  },
  "trustedDependencies": [
    "nx",
    "@biomejs/biome",
    "@prisma/client",
    "@prisma/engines",
    "@sentry/cli",
    "@swc/core",
    "core-js",
    "esbuild",
    "isolated-vm",
    "prisma",
    "sharp",
    "inngest-cli"
  ]
}
