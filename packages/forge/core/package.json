{
  "name": "@typebot.io/forge",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@typebot.io/variables": "workspace:*",
    "@typebot.io/runtime-session-store": "workspace:*",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
