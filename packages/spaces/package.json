{
  "name": "@typebot.io/spaces",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./core": {
      "types": "./src/core/Space.ts",
      "import": "./src/core/Space.ts",
      "default": "./src/core/Space.ts"
    },
    "./orpc/router": {
      "types": "./src/drivers/orpc/router.ts",
      "import": "./src/orpc/router.ts",
      "default": "./src/orpc/router.ts"
    },
    "./react/*": {
      "types": "./src/react/*.tsx",
      "import": "./src/react/*.tsx",
      "default": "./src/react/*.tsx"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@orpc/server": "^1.13.4",
    "effect": "^3.19.18",
    "@typebot.io/config": "workspace:*",
    "@typebot.io/domain-primitives": "workspace:*",
    "@typebot.io/prisma": "workspace:*",
    "@typebot.io/workspaces": "workspace:*",
    "@typebot.io/ui": "workspace:*",
    "@tanstack/react-form": "^1.28.3"
  },
  "nx": {
    "targets": {
      "test": {
        "executor": "@nx/vitest:test",
        "outputs": [
          "{options.reportsDirectory}"
        ],
        "options": {
          "reportsDirectory": "../../coverage/packages/spaces"
        }
      }
    }
  }
}
