{
  "name": "@typebot.io/campaigns",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./orpc/router": "./src/drivers/orpc/router.ts",
    "./core": "./src/domain/Campaign.ts",
    "./react/*": "./src/drivers/react/*.tsx",
    "./workflows/*": "./src/workflows/*.ts"
  },
  "dependencies": {
    "@orpc/server": "^1.13.4",
    "@typebot.io/config": "workspace:*",
    "@typebot.io/credentials": "workspace:*",
    "@typebot.io/shared-core": "workspace:*",
    "@typebot.io/shared-primitives": "workspace:*",
    "@typebot.io/prisma": "workspace:*",
    "@typebot.io/segments": "workspace:*",
    "@typebot.io/typebot": "workspace:*",
    "@typebot.io/ui": "workspace:*",
    "@typebot.io/user": "workspace:*",
    "@typebot.io/whatsapp": "workspace:*",
    "@typebot.io/workspaces": "workspace:*",
    "effect": "4.0.0-beta.30",
    "@testcontainers/postgresql": "^11.12.0"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.30",
    "vitest": "^4.0.18"
  },
  "nx": {
    "targets": {
      "test": {
        "executor": "@nx/vitest:test",
        "outputs": [
          "{options.reportsDirectory}"
        ],
        "options": {
          "configFile": "vitest.config.ts",
          "project": "@typebot.io/campaigns",
          "reportsDirectory": "../../coverage/packages/campaigns"
        }
      }
    }
  }
}
