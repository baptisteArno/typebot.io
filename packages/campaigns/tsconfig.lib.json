{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../domain-primitives/tsconfig.lib.json"
    },
    {
      "path": "../segments/tsconfig.lib.json"
    },
    {
      "path": "../ui/tsconfig.lib.json"
    },
    {
      "path": "../user/tsconfig.lib.json"
    },
    {
      "path": "../typebot/tsconfig.lib.json"
    },
    {
      "path": "../workspaces/tsconfig.lib.json"
    },
    {
      "path": "../prisma/tsconfig.lib.json"
    },
    {
      "path": "../credentials/tsconfig.lib.json"
    },
    {
      "path": "../whatsapp/tsconfig.lib.json"
    },
    {
      "path": "../config/tsconfig.lib.json"
    }
  ],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ]
