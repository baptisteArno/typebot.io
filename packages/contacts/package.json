{
  "name": "@typebot.io/contacts",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./orpc/router": {
      "types": "./src/drivers/orpc/router.ts",
      "import": "./src/drivers/orpc/router.ts",
      "default": "./src/drivers/orpc/router.ts"
    },
    "./react/*": "./src/drivers/react/*.tsx",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-table": "^8.9.3",
    "@orpc/server": "^1.13.4",
    "@typebot.io/config": "workspace:*",
    "@typebot.io/shared-core": "workspace:*",
    "@typebot.io/shared-primitives": "workspace:*",
    "@typebot.io/prisma": "workspace:*",
    "@typebot.io/ui": "workspace:*",
    "@typebot.io/user": "workspace:*",
    "@typebot.io/workspaces": "workspace:*",
    "effect": "4.0.0-beta.30"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.30"
  },
  "nx": {
    "targets": {
      "test": {
        "executor": "@nx/vitest:test",
        "outputs": [
          "{options.reportsDirectory}"
        ],
        "options": {
          "configFile": "vitest.config.ts",
          "project": "@typebot.io/contacts",
          "reportsDirectory": "../../coverage/packages/contacts"
        }
      }
    }
  }
}
