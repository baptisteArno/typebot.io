{
  "name": "@typebot.io/contacts",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./orpc/router": {
      "types": "./src/drivers/orpc/router.ts",
      "import": "./src/drivers/orpc/router.ts",
      "default": "./src/drivers/orpc/router.ts"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@orpc/server": "^1.13.4",
    "@typebot.io/config": "workspace:*",
    "@typebot.io/domain": "workspace:*",
    "@typebot.io/prisma": "workspace:*",
    "@typebot.io/user": "workspace:*",
    "@typebot.io/workspaces": "workspace:*",
    "effect": "^3.19.18"
  },
  "nx": {
    "targets": {
      "test": {
        "executor": "@nx/vitest:test",
        "outputs": [
          "{options.reportsDirectory}"
        ],
        "options": {
          "reportsDirectory": "../../coverage/packages/contacts"
        }
      }
    }
  }
}
