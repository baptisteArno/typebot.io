{
  "name": "@typebot.io/prisma",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./effect": {
      "types": "./.effect/index.ts",
      "import": "./.effect/index.ts",
      "default": "./.effect/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsx scripts/studio.ts",
    "db:generate": "tsx scripts/db-generate.ts",
    "db:generate:mysql": "DATABASE_URL=mysql:// tsx scripts/db-generate.ts",
    "db:push": "tsx scripts/db-push.ts",
    "migrate:deploy": "tsx scripts/migrate-deploy.ts",
    "create-migration-file": "prisma migrate dev --config prisma.config.ts --create-only --schema postgresql/schema.prisma",
    "db:migrate": "bun migrate:deploy",
    "reset": "prisma migrate reset --config prisma.config.ts --schema postgresql/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/adapter-planetscale": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@prisma/extension-read-replicas": "^0.5.0",
    "effect": "4.0.0-beta.30",
    "prisma": "^7.4.0"
  },
  "devDependencies": {
    "@prisma/generator-helper": "^7.4.0",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.1"
  }
}
